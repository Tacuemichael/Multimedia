<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".MainActivity">

    <!-- 1. Album Art / Image -->
    <ImageView
        android:id="@+id/imgAlbumArt"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/ic_launcher_background"
        android:contentDescription="Album Art"
        app:layout_constraintBottom_toTopOf="@+id/txtSongTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginBottom="20dp"/>

    <!-- 2. Song Title -->
    <TextView
        android:id="@+id/txtSongTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Audio Track"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/seekBarProgress"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imgAlbumArt"
        android:layout_marginBottom="20dp"/>

    <!-- 3. Progress Bar (SeekBar) -->
    <SeekBar
        android:id="@+id/seekBarProgress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtSongTitle"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:layout_marginTop="10dp"/>

    <!-- 4. Time Stamps (Optional but good for UI) -->
    <TextView
        android:id="@+id/txtCurrentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#AAAAAA"
        app:layout_constraintStart_toStartOf="@+id/seekBarProgress"
        app:layout_constraintTop_toBottomOf="@+id/seekBarProgress"/>

    <TextView
        android:id="@+id/txtTotalTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#AAAAA"
        app:layout_constraintEnd_toEndOf="@+id/seekBarProgress"
        app:layout_constraintTop_toBottomOf="@+id/seekBarProgress"/>

    <!-- 5. Control Buttons (Play, Pause, Stop) -->
    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/seekBarProgress"
        android:layout_marginTop="40dp">


    </LinearLayout>

    <!-- 6. THE WATERMARK (tacuemichael) -->
    <TextView
        android:id="@+id/txtWatermark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="tacuemichael"
        android:textSize="40sp"
        android:textColor="#FFFFFF"
        android:alpha="0.1"
        android:textStyle="bold"
        android:rotation="-45"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>